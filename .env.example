# Copy this file to .env and change every replace/change value before deployment.
# Non-secret startup settings live in config.yaml.

SUB2API_ADMIN_API_KEY=replace-me
SUB2API_US_PROXY_2_ADMIN_API_KEY=replace-me-too

# Optional override for config.yaml sub2api.api_key_group_selection: first or random.
# SUB2API_API_KEY_GROUP_SELECTION=random

POSTGRES_PASSWORD=change-me-postgres-password

# Set this for normal deployments. If omitted, startup logs print a temporary password.
APP_AUTH_PASSWORD=change-me
